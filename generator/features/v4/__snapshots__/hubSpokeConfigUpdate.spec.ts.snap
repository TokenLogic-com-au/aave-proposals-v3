        assertEq(uint256(cfg.addCap), uint256(1_000_000), 'addCap mismatch');
        assertEq(uint256(cfg.drawCap), uint256(500_000), 'drawCap mismatch');
        assertEq(uint256(cfg.riskPremiumThreshold), uint256(before.riskPremiumThreshold), 'riskPremiumThreshold unchanged');
        assertTrue(cfg.active, 'active should be true');
        assertEq(cfg.halted, before.halted, 'halted unchanged');
      }",
