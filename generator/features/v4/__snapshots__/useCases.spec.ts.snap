      "test": "// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

import {GovV3Helpers} from 'aave-helpers/src/GovV3Helpers.sol';
import {AaveV4EthereumHubs, AaveV4EthereumAssets, AaveV4EthereumSpokes, AaveV4Ethereum} from 'aave-address-book/AaveV4Ethereum.sol';
import {IHub} from 'aave-v4/hub/interfaces/IHub.sol';
import {ISpoke} from 'aave-v4/spoke/interfaces/ISpoke.sol';
import {IAssetInterestRateStrategy} from 'aave-v4/hub/interfaces/IAssetInterestRateStrategy.sol';
import {IAccessManager} from 'aave-v4/dependencies/openzeppelin/IAccessManager.sol';
import {IPositionManagerBase} from 'aave-v4/position-manager/interfaces/IPositionManagerBase.sol';
import {IERC20Metadata} from 'openzeppelin-contracts/contracts/token/ERC20/extensions/IERC20Metadata.sol';

import 'forge-std/Test.sol';
import {ProtocolV4TestBase} from 'aave-helpers/src/ProtocolV4TestBase.sol';
import {AaveV4Ethereum_V4EveryUseCase_20260521} from './AaveV4Ethereum_V4EveryUseCase_20260521.sol';

/**
 * @dev Test for AaveV4Ethereum_V4EveryUseCase_20260521
 * command: FOUNDRY_PROFILE=test forge test --match-path=src/20260521_AaveV4Ethereum_V4EveryUseCase/AaveV4Ethereum_V4EveryUseCase_20260521.t.sol -vv
 */
contract AaveV4Ethereum_V4EveryUseCase_20260521_Test is ProtocolV4TestBase {
  AaveV4Ethereum_V4EveryUseCase_20260521 internal proposal;

  function setUp() public {
    vm.createSelectFork(vm.rpcUrl('mainnet'), 42);
    proposal = new AaveV4Ethereum_V4EveryUseCase_20260521();
  }

  /**
   * @dev executes the generic test suite including e2e and config snapshots
   * forge-config: default.isolate = true
   */
  function test_defaultProposalExecution() public {
    defaultTest('AaveV4Ethereum_V4EveryUseCase_20260521', address(proposal));
  }

  function test_hubAssetListing_CORE_HUB_WETH() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    assertTrue(hub.isUnderlyingListed(AaveV4EthereumAssets.WETH_UNDERLYING), 'asset not listed');
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.WETH_UNDERLYING);
    IHub.Asset memory asset = hub.getAsset(assetId);
    IHub.AssetConfig memory cfg = hub.getAssetConfig(assetId);
    assertEq(asset.underlying, AaveV4EthereumAssets.WETH_UNDERLYING, 'underlying mismatch');
    assertEq(
      uint256(asset.decimals),
      IERC20Metadata(AaveV4EthereumAssets.WETH_UNDERLYING).decimals(),
      'decimals mismatch'
    );
    assertEq(cfg.feeReceiver, proposal.CORE_HUB_WETH_FEE_RECEIVER(), 'feeReceiver mismatch');
    assertEq(cfg.irStrategy, proposal.CORE_HUB_WETH_IR_STRATEGY(), 'irStrategy mismatch');
    assertEq(uint256(cfg.liquidityFee), uint256(100), 'liquidityFee mismatch');
    IAssetInterestRateStrategy.InterestRateData memory irData = IAssetInterestRateStrategy(
      cfg.irStrategy
    ).getInterestRateData(assetId);
    assertEq(uint256(irData.optimalUsageRatio), uint256(8000), 'optimalUsageRatio mismatch');
    assertEq(uint256(irData.baseDrawnRate), uint256(0), 'baseDrawnRate mismatch');
    assertEq(
      uint256(irData.rateGrowthBeforeOptimal),
      uint256(400),
      'rateGrowthBeforeOptimal mismatch'
    );
    assertEq(
      uint256(irData.rateGrowthAfterOptimal),
      uint256(6000),
      'rateGrowthAfterOptimal mismatch'
    );
  }
  function test_hubSpokeToAssetsAddition_CORE_HUB_MAIN_SPOKE_WETH() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.WETH_UNDERLYING);
    assertTrue(
      hub.isSpokeListed(assetId, address(AaveV4EthereumSpokes.MAIN_SPOKE)),
      'spoke not listed'
    );
    IHub.SpokeConfig memory cfg = hub.getSpokeConfig(
      assetId,
      address(AaveV4EthereumSpokes.MAIN_SPOKE)
    );
    assertEq(uint256(cfg.addCap), uint256(1000), 'addCap mismatch');
    assertEq(uint256(cfg.drawCap), uint256(500), 'drawCap mismatch');
    assertEq(uint256(cfg.riskPremiumThreshold), uint256(100), 'riskPremiumThreshold mismatch');
    assertEq(cfg.active, true, 'active mismatch');
    assertEq(cfg.halted, false, 'halted mismatch');
  }
  function test_hubAssetListing_CORE_HUB_USDC() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    assertTrue(hub.isUnderlyingListed(AaveV4EthereumAssets.USDC_UNDERLYING), 'asset not listed');
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.USDC_UNDERLYING);
    IHub.Asset memory asset = hub.getAsset(assetId);
    IHub.AssetConfig memory cfg = hub.getAssetConfig(assetId);
    assertEq(asset.underlying, AaveV4EthereumAssets.USDC_UNDERLYING, 'underlying mismatch');
    assertEq(
      uint256(asset.decimals),
      IERC20Metadata(AaveV4EthereumAssets.USDC_UNDERLYING).decimals(),
      'decimals mismatch'
    );
    assertEq(cfg.feeReceiver, proposal.CORE_HUB_USDC_FEE_RECEIVER(), 'feeReceiver mismatch');
    assertEq(cfg.irStrategy, proposal.CORE_HUB_USDC_IR_STRATEGY(), 'irStrategy mismatch');
    assertEq(uint256(cfg.liquidityFee), uint256(100), 'liquidityFee mismatch');
    IAssetInterestRateStrategy.InterestRateData memory irData = IAssetInterestRateStrategy(
      cfg.irStrategy
    ).getInterestRateData(assetId);
    assertEq(uint256(irData.optimalUsageRatio), uint256(8000), 'optimalUsageRatio mismatch');
    assertEq(uint256(irData.baseDrawnRate), uint256(0), 'baseDrawnRate mismatch');
    assertEq(
      uint256(irData.rateGrowthBeforeOptimal),
      uint256(400),
      'rateGrowthBeforeOptimal mismatch'
    );
    assertEq(
      uint256(irData.rateGrowthAfterOptimal),
      uint256(6000),
      'rateGrowthAfterOptimal mismatch'
    );
  }
  function test_spokeReserveListing_MAIN_SPOKE_USDC() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    ISpoke spoke = ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.USDC_UNDERLYING);
    uint256 reserveId = spoke.getReserveId(address(hub), assetId);
    ISpoke.Reserve memory reserve = spoke.getReserve(reserveId);
    ISpoke.ReserveConfig memory cfg = spoke.getReserveConfig(reserveId);
    assertEq(reserve.underlying, AaveV4EthereumAssets.USDC_UNDERLYING, 'underlying mismatch');
    assertEq(address(reserve.hub), address(hub), 'hub mismatch');
    assertEq(uint256(reserve.assetId), assetId, 'assetId mismatch');
    assertEq(
      uint256(reserve.decimals),
      IERC20Metadata(AaveV4EthereumAssets.USDC_UNDERLYING).decimals(),
      'decimals mismatch'
    );
    assertEq(uint256(cfg.collateralRisk), uint256(0), 'collateralRisk mismatch');
    assertEq(cfg.paused, false, 'paused mismatch');
    assertEq(cfg.frozen, false, 'frozen mismatch');
    assertEq(cfg.borrowable, true, 'borrowable mismatch');
    assertEq(cfg.receiveSharesEnabled, true, 'receiveSharesEnabled mismatch');
    ISpoke.DynamicReserveConfig memory dyn = spoke.getDynamicReserveConfig(
      reserveId,
      reserve.dynamicConfigKey
    );
    assertEq(uint256(dyn.collateralFactor), uint256(8000), 'collateralFactor mismatch');
    assertEq(uint256(dyn.maxLiquidationBonus), uint256(500), 'maxLiquidationBonus mismatch');
    assertEq(uint256(dyn.liquidationFee), uint256(100), 'liquidationFee mismatch');
  }
  function test_hubSpokeToAssetsAddition_CORE_HUB_MAIN_SPOKE_USDC() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.USDC_UNDERLYING);
    assertTrue(
      hub.isSpokeListed(assetId, address(AaveV4EthereumSpokes.MAIN_SPOKE)),
      'spoke not listed'
    );
    IHub.SpokeConfig memory cfg = hub.getSpokeConfig(
      assetId,
      address(AaveV4EthereumSpokes.MAIN_SPOKE)
    );
    assertEq(uint256(cfg.addCap), uint256(1000), 'addCap mismatch');
    assertEq(uint256(cfg.drawCap), uint256(500), 'drawCap mismatch');
    assertEq(uint256(cfg.riskPremiumThreshold), uint256(100), 'riskPremiumThreshold mismatch');
    assertEq(cfg.active, true, 'active mismatch');
    assertEq(cfg.halted, false, 'halted mismatch');
  }
  function test_hubSpokeConfigUpdate_CORE_HUB_MAIN_SPOKE_WETH() public {
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.WETH_UNDERLYING);
    IHub.SpokeConfig memory before = hub.getSpokeConfig(
      assetId,
      address(AaveV4EthereumSpokes.MAIN_SPOKE)
    );
    GovV3Helpers.executePayload(vm, address(proposal));
    IHub.SpokeConfig memory cfg = hub.getSpokeConfig(
      assetId,
      address(AaveV4EthereumSpokes.MAIN_SPOKE)
    );
    assertEq(uint256(cfg.addCap), uint256(1_000_000), 'addCap mismatch');
    assertEq(uint256(cfg.drawCap), uint256(before.drawCap), 'drawCap unchanged');
    assertEq(
      uint256(cfg.riskPremiumThreshold),
      uint256(before.riskPremiumThreshold),
      'riskPremiumThreshold unchanged'
    );
    assertTrue(cfg.active, 'active should be true');
    assertEq(cfg.halted, before.halted, 'halted unchanged');
  }
  function test_spokeReserveConfigUpdate_MAIN_SPOKE_WETH() public {
    ISpoke spoke = ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.WETH_UNDERLYING);
    uint256 reserveId = spoke.getReserveId(address(hub), assetId);
    ISpoke.ReserveConfig memory before = spoke.getReserveConfig(reserveId);
    GovV3Helpers.executePayload(vm, address(proposal));
    ISpoke.ReserveConfig memory cfg = spoke.getReserveConfig(reserveId);
    assertEq(uint256(cfg.collateralRisk), uint256(7000), 'collateralRisk mismatch');
    assertEq(cfg.paused, before.paused, 'paused unchanged');
    assertEq(cfg.frozen, before.frozen, 'frozen unchanged');
    assertEq(cfg.borrowable, before.borrowable, 'borrowable unchanged');
    assertEq(
      cfg.receiveSharesEnabled,
      before.receiveSharesEnabled,
      'receiveSharesEnabled unchanged'
    );
  }
  function test_spokeLiquidationConfigUpdate_MAIN_SPOKE() public {
    ISpoke.LiquidationConfig memory before = ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE))
      .getLiquidationConfig();
    GovV3Helpers.executePayload(vm, address(proposal));
    ISpoke.LiquidationConfig memory cfg = ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE))
      .getLiquidationConfig();
    assertEq(
      uint256(cfg.targetHealthFactor),
      uint256(1_500_000_000_000_000_000),
      'targetHealthFactor mismatch'
    );
    assertEq(
      uint256(cfg.healthFactorForMaxBonus),
      uint256(before.healthFactorForMaxBonus),
      'healthFactorForMaxBonus unchanged'
    );
    assertEq(uint256(cfg.liquidationBonusFactor), uint256(500), 'liquidationBonusFactor mismatch');
  }
  function test_spokeDynamicReserveConfigUpdate_MAIN_SPOKE_WETH_1() public {
    ISpoke spoke = ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE));
    IHub hub = IHub(address(AaveV4EthereumHubs.CORE_HUB));
    uint256 assetId = hub.getAssetId(AaveV4EthereumAssets.WETH_UNDERLYING);
    uint256 reserveId = spoke.getReserveId(address(hub), assetId);
    ISpoke.DynamicReserveConfig memory beforeDyn = spoke.getDynamicReserveConfig(
      reserveId,
      uint32(1)
    );
    GovV3Helpers.executePayload(vm, address(proposal));
    ISpoke.DynamicReserveConfig memory dyn = spoke.getDynamicReserveConfig(reserveId, uint32(1));
    assertEq(uint256(dyn.collateralFactor), uint256(7700), 'collateralFactor mismatch');
    assertEq(
      uint256(dyn.maxLiquidationBonus),
      uint256(beforeDyn.maxLiquidationBonus),
      'maxLiquidationBonus unchanged'
    );
    assertEq(
      uint256(dyn.liquidationFee),
      uint256(beforeDyn.liquidationFee),
      'liquidationFee unchanged'
    );
  }
  function test_accessManagerTargetFunctionRoleUpdate_1_0_0() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    assertEq(
      uint256(
        IAccessManager(address(AaveV4Ethereum.ACCESS_MANAGER)).getTargetFunctionRole(
          proposal.ROLE_1_TARGET_0(),
          bytes4(0x12345678)
        )
      ),
      uint256(1),
      'selector role mismatch'
    );
  }
  function test_spokePositionManagerUpdate_MAIN_SPOKE_0x1111111111111111111111111111111111111111_0()
    public
  {
    GovV3Helpers.executePayload(vm, address(proposal));
    assertEq(
      ISpoke(address(AaveV4EthereumSpokes.MAIN_SPOKE)).isPositionManagerActive(
        address(0x1111111111111111111111111111111111111111)
      ),
      true,
      'positionManager active mismatch'
    );
  }
  function test_positionManagerSpokeRegistration_0x1111111111111111111111111111111111111111_MAIN_SPOKE_0()
    public
  {
    GovV3Helpers.executePayload(vm, address(proposal));
    assertEq(
      IPositionManagerBase(address(0x1111111111111111111111111111111111111111)).isSpokeRegistered(
        address(AaveV4EthereumSpokes.MAIN_SPOKE)
      ),
      true,
      'spoke registration mismatch'
    );
  }
  function test_accessManagerRoleMembership_1_0() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    (bool isMember, uint32 executionDelay) = IAccessManager(address(AaveV4Ethereum.ACCESS_MANAGER))
      .hasRole(uint64(1), proposal.ROLE_1_ACCOUNT_0());
    assertTrue(isMember, 'account should have role');
    assertEq(uint256(executionDelay), uint256(0), 'executionDelay mismatch');
  }
  function test_accessManagerRoleUpdate_1_0() public {
    GovV3Helpers.executePayload(vm, address(proposal));
    assertEq(
      uint256(IAccessManager(address(AaveV4Ethereum.ACCESS_MANAGER)).getRoleGuardian(uint64(1))),
      uint256(2),
      'guardian mismatch'
    );
  }
}
